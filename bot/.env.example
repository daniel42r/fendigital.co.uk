# ---- Required ----
# Get your key from https://the-odds-api.com/ (free tier: 500 req/month)
ODDS_API_KEY=your_odds_api_key_here

# Get from @BotFather on Telegram after /newbot
TELEGRAM_BOT_TOKEN=123456:ABC-your-bot-token

# Your numeric chat id. Send any message to your bot, then visit
# https://api.telegram.org/bot<TOKEN>/getUpdates and copy "chat.id".
TELEGRAM_CHAT_ID=123456789

# ---- Optional (defaults shown) ----

# Seconds between polling cycles. Each cycle hits the API once per sport.
# Quota-aware guidance (assuming 5 sports enabled):
#   30s  = ~432k req/month  (needs $119/mo plan)
#   60s  = ~216k req/month  (needs $119/mo plan)
#   300s = ~43k req/month   ($30/mo plan)
#   900s = ~14k req/month   ($10/mo plan)
#   3600s= ~3.6k req/month  (fits $10/mo plan comfortably)
POLL_INTERVAL_SEC=30

# Comma-separated Odds API sport keys. Full list: /v4/sports endpoint.
SPORTS=soccer_epl,soccer_uefa_champs_league,basketball_nba,americanfootball_nfl,mma_mixed_martial_arts

# Comma-separated regions: uk, eu, us, au
REGIONS=uk,eu,us

# Minimum profit % to alert on. 0.5 = only flag arbs with >=0.5% margin.
# Set to a negative value (e.g. -5.0) to force alerts on every match for testing.
MIN_PROFIT_PCT=0.5

# Hypothetical total stake used when computing per-leg stake splits in messages.
TOTAL_STAKE=100

# DEBUG, INFO, WARNING, ERROR
LOG_LEVEL=INFO
